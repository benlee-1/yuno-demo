# Yuno sandbox credentials — copy to .env.local and fill in.
# Get these from the Yuno dashboard (Developers > API keys), SANDBOX environment.
# NEVER commit .env.local. NEVER use production keys in this demo.

# Account code (used as account_id in checkout sessions / payments)
YUNO_ACCOUNT_CODE=

# Public API key (server-side use)
YUNO_PUBLIC_API_KEY=

# Same value as YUNO_PUBLIC_API_KEY — exposed to the browser for the Web SDK
NEXT_PUBLIC_YUNO_PUBLIC_API_KEY=

# Private secret key — server-only. Never logged, never sent to the client.
YUNO_PRIVATE_SECRET_KEY=

# Webhook HMAC secret — set to the secret configured in the Yuno dashboard
# (Developers > Webhooks, HMAC authentication). Optional: if unset, incoming
# webhooks are accepted unverified and marked as such in the event log.
YUNO_WEBHOOK_SECRET=

# Anthropic API key — powers the Payments Concierge ops agent (/ops)
ANTHROPIC_API_KEY=

# Yuno API base URL — keep pointed at sandbox
YUNO_API_URL=https://api-sandbox.y.uno
