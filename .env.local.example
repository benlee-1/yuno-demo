# Yuno sandbox credentials — copy to .env.local and fill in.
# Get these from the Yuno dashboard (Developers > API keys), SANDBOX environment.
# NEVER commit .env.local. NEVER use production keys in this demo.

# Account code (used as account_id in checkout sessions / payments)
YUNO_ACCOUNT_CODE=

# Public API key (server-side use)
YUNO_PUBLIC_API_KEY=

# Same value as YUNO_PUBLIC_API_KEY — exposed to the browser for the Web SDK
NEXT_PUBLIC_YUNO_PUBLIC_API_KEY=

# Private secret key — server-only. Never logged, never sent to the client.
YUNO_PRIVATE_SECRET_KEY=

# Webhook auth — all three optional; any that are set get verified on every
# delivery (mismatch -> 401 + logged, order state untouched). Values must match
# what you enter in the Yuno dashboard webhook form (Developers > Webhooks):
# YUNO_WEBHOOK_SECRET      <-> "Use HMAC signing" secret (x-hmac-signature)
# YUNO_WEBHOOK_API_KEY     <-> the form's x-api-key field
# YUNO_WEBHOOK_API_SECRET  <-> the form's x-secret field
YUNO_WEBHOOK_SECRET=
YUNO_WEBHOOK_API_KEY=
YUNO_WEBHOOK_API_SECRET=

# OpenRouter API key — preferred: routes the ops agent (/ops) through
# OpenRouter for provider portability. Get a key at openrouter.ai/keys.
OPENROUTER_API_KEY=

# Anthropic API key — fallback alternative to OPENROUTER_API_KEY: calls
# Anthropic directly. Only used when OPENROUTER_API_KEY is unset.
ANTHROPIC_API_KEY=

# Optional model override for the ops agent. Defaults:
# anthropic/claude-sonnet-5 (via OpenRouter) / claude-sonnet-5 (direct Anthropic).
# e.g. AGENT_MODEL=anthropic/claude-opus-4.8 for OpenRouter,
#      AGENT_MODEL=claude-opus-4-8 for direct Anthropic.
AGENT_MODEL=

# Yuno API base URL — keep pointed at sandbox
YUNO_API_URL=https://api-sandbox.y.uno

# --- Feature Playground (BYO-credentials workspaces) -----------------------

# Gates /admin and /api/admin/*. Long random string; unset = admin disabled
# (fails closed). Generate: openssl rand -hex 24
ADMIN_CODE=

# Master key for the playground: encrypts stored workspace private keys
# (AES-256-GCM) and signs /w/<token> links. Long random string; unset =
# playground disabled. ROTATING IT INVALIDATES all stored workspace secrets
# and every outstanding link. Generate: openssl rand -hex 32
WORKSPACE_ENC_KEY=

# Lifetime cap on attempted payments per playground workspace (anti
# card-testing). Default 200.
PLAYGROUND_MAX_PAYMENTS=
